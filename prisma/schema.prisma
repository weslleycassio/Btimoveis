generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CORD
  CORRETOR
  USER
}

enum ImovelStatus {
  ATIVO
  INATIVO
}

model User {
  id           String   @id
  nome         String
  telefone     String?
  email        String   @unique
  passwordHash String
  role         UserRole
  imoveisCaptados Imovel[] @relation("ImovelCaptador")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Imovel {
  id                String       @id @default(cuid())
  titulo            String
  tipo              String
  finalidade        String
  bairro            String
  cidade            String
  preco             Decimal      @db.Decimal(14, 2)
  descricao         String?
  status            ImovelStatus @default(ATIVO)
  corretorCaptadorId String
  corretorCaptador  User         @relation("ImovelCaptador", fields: [corretorCaptadorId], references: [id])
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([corretorCaptadorId])
}
