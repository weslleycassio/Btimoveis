generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CORRETOR
}

enum RegistroStatus {
  ATIVO
  INATIVO
}

enum ImovelStatus {
  ATIVO
  INATIVO
}

model Imobiliaria {
  id          String         @id @default(cuid())
  nome        String
  telefone    String
  email       String?
  cnpj        String?
  status      RegistroStatus @default(ATIVO)
  users       User[]
  imoveis     Imovel[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model User {
  id            String         @id @default(cuid())
  nome          String
  telefone      String
  email         String         @unique
  passwordHash  String
  role          UserRole       @default(ADMIN)
  status        RegistroStatus @default(ATIVO)
  imobiliariaId String
  imobiliaria   Imobiliaria    @relation(fields: [imobiliariaId], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Imovel {
  id            String       @id @default(cuid())
  titulo         String
  tipo           String
  finalidade     String
  bairro         String
  cidade         String
  preco          Decimal      @db.Decimal(14, 2)
  descricao      String?
  status         ImovelStatus @default(ATIVO)
  imobiliariaId  String
  imobiliaria    Imobiliaria  @relation(fields: [imobiliariaId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}
