generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CORD
  CORRETOR
  USER
}

enum ImovelStatus {
  ATIVO
  INATIVO
}

model User {
  id           String   @id
  nome         String
  telefone     String?
  email        String   @unique
  passwordHash String
  role         UserRole
  imoveisCaptados Imovel[] @relation("ImovelCaptador")
  imovelEdicoes  ImovelEdicao[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Imovel {
  id                String       @id @default(cuid())
  titulo            String
  tipo              String
  finalidade        String
  bairro            String
  cidade            String
  preco             Decimal      @db.Decimal(14, 2)
  descricao         String?
  status            ImovelStatus @default(ATIVO)
  corretorCaptadorId String
  corretorCaptador  User         @relation("ImovelCaptador", fields: [corretorCaptadorId], references: [id])
  edicoes           ImovelEdicao[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([corretorCaptadorId])
}

model ImovelEdicao {
  id               String   @id @default(cuid())
  imovelId         String
  editadoPorUserId String
  motivoEdicao     String
  camposAlterados  Json?
  createdAt        DateTime @default(now())

  imovel           Imovel   @relation(fields: [imovelId], references: [id], onDelete: Cascade)
  editadoPor       User     @relation(fields: [editadoPorUserId], references: [id], onDelete: Restrict)

  @@index([imovelId])
  @@index([editadoPorUserId])
}
